	"item": [
		{
			"name": "0. Authentication & Webhooks",
			"item": [
				{
					"name": "Get Bearer Token (Live)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json(); if (jsonData.token) { pm.environment.set(\"bearerToken\", jsonData.token); pm.collectionVariables.set(\"bearerToken\", jsonData.token); }"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"client_key\": \"YOUR_KEY_HERE\",\n    \"client_secret\": \"YOUR_SECRET_HERE\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "https://setugeo.com/api/v1/auth/token"
						}
					},
					"response": [
						{
							"name": "Token Success",
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"body": "{\n    \"success\": true,\n    \"token\": \"eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"expires_at\": \"2026-12-31 23:59:59\"\n}"
						}
					]
				},
				{
					"name": "User Usage Stats",
					"request": {
						"method": "GET",
						"url": {
							"raw": "{{baseUrl}}/user/usage"
						}
					},
					"response": [
						{
