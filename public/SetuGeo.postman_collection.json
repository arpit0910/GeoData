{
	"info": {
		"_postman_id": "c661300e-1800-4b74-9da3-c08a53831dd1",
		"name": "SetuGeo Premium API - Full Suite",
		"description": "The definitive Postman collection for SetuGeo. Includes recursive geographic drills, advanced banking analytics, geospatial clustering, and financial conversion tools. Designed for immediate production-ready testing.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "0. Authentication Service",
			"description": "Essential endpoints to manage access. You must generate a Bearer Token here before calling any other resource.",
			"item": [
				{
					"name": "Get Bearer Token",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"client_key\": \"YOUR_KEY_HERE\",\n    \"client_secret\": \"YOUR_SECRET_HERE\"\n}",
							"options": { "raw": { "language": "json" } }
						},
						"url": { "raw": "{{baseUrl}}/auth/token" },
						"description": "Returns a high-security access token valid for 24 hours. Rate limited to 10 requests per minute per client."
					},
					"response": [
						{
							"name": "Success Response",
							"originalRequest": {
								"method": "POST",
								"header": [],
								"body": { "mode": "raw", "raw": "{\n    \"client_key\": \"...\",\n    \"client_secret\": \"...\"\n}" },
								"url": { "raw": "{{baseUrl}}/auth/token" }
							},
							"status": "OK",
							"code": 200,
							"_postman_previewlanguage": "json",
							"header": [],
							"cookie": [],
							"body": "{\n    \"success\": true,\n    \"data\": {\n        \"access_token\": \"3|V6q...\",\n        \"token_type\": \"Bearer\",\n        \"expires_in\": 86400\n    }\n}"
						}
					]
				}
			]
		},
		{
			"name": "1. Geographic Mastery",
			"description": "Hierarchical lookups and detailed descriptions of world regions, countries, states, and cities.",
			"item": [
				{
					"name": "Countries - Global Search",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/countries?name=India&iso2=IN",
							"query": [
								{ "key": "name", "value": "India", "description": "Search by full or partial name" },
								{ "key": "iso2", "value": "IN", "description": "Filter by 2-character ISO code" }
							]
						},
						"description": "Retrieve list of countries with core data (Currency, Capital, Population)."
					},
					"response": [
						{
							"name": "Single Item Example",
							"status": "OK",
							"code": 200,
							"body": "{\n    \"success\": true,\n    \"data\": [\n        {\n            \"id\": 101,\n            \"name\": \"India\",\n            \"iso2\": \"IN\",\n            \"iso3\": \"IND\",\n            \"currency\": \"INR\",\n            \"capital\": \"New Delhi\",\n            \"population\": \"1400000000\"\n        }\n    ]\n}"
						}
					]
				},
				{
					"name": "Drill - States within Country",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/countries/101/states" },
						"description": "Fetch all first-level administrative divisions (States/Provinces) of a country."
					},
					"response": []
				},
				{
					"name": "Drill - Cities within State",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/states/51/cities" }
					},
					"response": []
				}
			]
		},
		{
			"name": "2. Banking & Finance",
			"description": "Deep-search banking infrastructure, IFSC validation, and financial coverage analysis.",
			"item": [
				{
					"name": "Global Branch Search",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/branch/search?q=HDFC Mumbai&limit=5",
							"query": [
								{ "key": "q", "value": "HDFC Mumbai", "description": "Combined search query: Bank + City or IFSC fragment" },
								{ "key": "limit", "value": "5", "description": "Number of results to return" }
							]
						}
					},
					"response": [
						{
							"name": "Multiple Results Example",
							"status": "OK",
							"code": 200,
							"body": "{\n    \"success\": true,\n    \"data\": [\n        {\n            \"ifsc\": \"HDFC0000060\",\n            \"bank\": \"HDFC BANK\",\n            \"branch\": \"FORT\",\n            \"city\": \"MUMBAI\",\n            \"state\": \"MAHARASHTRA\"\n        }\n    ]\n}"
						}
					]
				},
				{
					"name": "Coverage Analysis",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{baseUrl}}/banks/1/coverage" },
						"description": "Get a statistical breakdown of a bank's presence across different states."
					},
					"response": []
				}
			]
		},
		{
			"name": "3. Geospatial Intelligence",
			"description": "Advanced coordinate-based operations including distance, radius, and reverse geocoding.",
			"item": [
				{
					"name": "Reverse Geocide",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/geospatial/geocode?lat=18.921&lng=72.834",
							"query": [
								{ "key": "lat", "value": "18.921" },
								{ "key": "lng", "value": "72.834" }
							]
						},
						"description": "Converts Lat/Lng coordinates into the nearest high-fidelity city/state data."
					},
					"response": [
						{
							"name": "Geocode Result",
							"status": "OK",
							"code": 200,
							"body": "{\n    \"success\": true,\n    \"data\": {\n        \"formatted_address\": \"Mumbai, Maharashtra, India\",\n        \"city\": \"Mumbai\",\n        \"distance_km\": 0.45\n    }\n}"
						}
					]
				},
				{
					"name": "Radius Search (Nearby Cities)",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/geospatial/nearby?lat=19.0&lng=72.8&radius=100&type=city",
							"query": [
								{ "key": "lat", "value": "19.0" },
								{ "key": "lng", "value": "72.8" },
								{ "key": "radius", "value": "100", "description": "Radius in kilometers" },
								{ "key": "type", "value": "city", "description": "Object type: city or pincode" }
							]
						}
					}
				}
			]
		},
		{
			"name": "4. Intelligent Utilities",
			"description": "Cross-domain conversion and validation tools.",
			"item": [
				{
					"name": "Currency - Powerful Converter",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/currency/convert?from=USD&to=INR&amount=100",
							"query": [
								{ "key": "from", "value": "USD" },
								{ "key": "to", "value": "INR" },
								{ "key": "amount", "value": "100" }
							]
						}
					},
					"response": [
						{
							"name": "Conversion Example",
							"status": "OK",
							"code": 200,
							"body": "{\n    \"success\": true,\n    \"data\": {\n        \"from\": \"USD\",\n        \"to\": \"INR\",\n        \"amount\": 100,\n        \"result\": \"8345.50\",\n        \"rate\": 83.455\n    }\n}"
						}
					]
				},
				{
					"name": "Address - Intelligent Autocomplete",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/address/autocomplete?q=Mum",
							"query": [
								{ "key": "q", "value": "Mum", "description": "Search string (minimum 2 chars)" }
							]
						}
					}
				}
			]
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [ { "key": "token", "value": "{{bearerToken}}", "type": "string" } ]
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://127.0.0.1:8000/api/v1", "type": "string" },
		{ "key": "bearerToken", "value": "YOUR_JWT_HERE", "type": "string" }
	]
}