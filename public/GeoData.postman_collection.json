{
	"info": {
		"_postman_id": "8b9cad0e-1f20-4192-bff0-e1e043ce143d",
		"name": "GeoData API - Full Portfolio",
		"description": "Exhaustive, import-ready Postman collection for all 10 GeoData endpoints. Automates token extraction for seamless testing.",
